---
import Layout from '../layouts/Layout.astro';
import { getEnv } from '../lib/runtime';
import { THEMES } from '../lib/types';

export const prerender = false;

const env = getEnv(Astro);
const defaultTheme = THEMES[0];
---

<Layout
  title="Wellspring — a wellspring of warm words"
  bg={defaultTheme.bg}
  pattern={defaultTheme.pattern}
  patternSize={defaultTheme.patternSize}
>
  <main class="container">
    <section style="text-align:center; margin: 80px 0 48px;">
      <h1 style="font-size: 56px; margin: 0 0 6px; font-family: Georgia, 'Iowan Old Style', 'Palatino Linotype', serif; letter-spacing: -0.02em;">Wellspring</h1>
      <p style="font-size: 16px; color: var(--muted); margin: 0 0 20px; letter-spacing: 0.05em; text-transform: uppercase;">a wellspring of warm words</p>
      <p style="font-size: 18px; color: var(--ink); max-width: 560px; margin: 0 auto 36px; line-height: 1.6;">
        A shared card for the people who matter. Birthdays, promotions, anniversaries,
        farewells, thank-yous — friends and teammates sign in messages, drop a photo or
        GIF, and you get a beautiful keepsake to send them.
      </p>
      <a href="/create" class="btn" style="font-size:16px; padding:14px 32px;">Create a board →</a>
    </section>
  </main>
</Layout>
