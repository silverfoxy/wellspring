---
import { getRequestIdentity, getEnv } from '../lib/runtime';

interface Props {
  title?: string;
  bg?: string;
  pattern?: string;
  patternSize?: string;
  isPrint?: boolean;
  hideNav?: boolean;
}
const { title = 'Wellspring', bg, pattern, patternSize, isPrint = false, hideNav = false } = Astro.props;
const bodyStyles: string[] = [];
if (bg) bodyStyles.push(`--page-bg: ${bg}`);
if (pattern) bodyStyles.push(`--page-pattern: ${pattern}`);
if (patternSize) bodyStyles.push(`--page-pattern-size: ${patternSize}`);
const bodyStyle = bodyStyles.length ? bodyStyles.join('; ') + ';' : undefined;
const identity = getRequestIdentity(Astro);
const env = getEnv(Astro);
const accessConfigured = Boolean(env.ACCESS_TEAM_DOMAIN && env.ACCESS_AUD);
const logoutUrl = accessConfigured ? '/api/logout' : null;
const loginUrl = (accessConfigured && !identity.isAuthenticated)
  ? `/signin?from=${encodeURIComponent(Astro.request.url)}`
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <style is:inline>
      :root {
        --ink: #1f2937;
        --muted: #6b7280;
        --card: #ffffff;
        --accent: #4f46e5;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        color: var(--ink);
        min-height: 100vh;
        background: var(--page-bg, #f9fafb);
        position: relative;
      }
      body::before {
        content: '';
        position: fixed;
        top: 0; right: 0; bottom: 0; left: 0;
        background-image: var(--page-pattern, none);
        background-size: var(--page-pattern-size, 80px 80px);
        background-repeat: repeat;
        pointer-events: none;
        z-index: 0;
      }
      body > * { position: relative; z-index: 1; }
      a { color: var(--accent); }
      .container { max-width: 1100px; margin: 0 auto; padding: 24px; }
      .nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; gap: 16px; flex-wrap: wrap; }
      .nav-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; min-width: 0; }
      .nav-email { max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      @media (max-width: 480px) {
        .nav-email { max-width: 120px; }
        .btn { padding: 8px 12px; font-size: 13px; }
      }
      .nav a { text-decoration: none; font-weight: 600; color: var(--ink); }
      .brand { display: inline-flex; flex-direction: column; line-height: 1.1; gap: 2px; }
      .brand-name {
        font-family: Georgia, 'Iowan Old Style', 'Palatino Linotype', serif;
        font-size: 22px; font-weight: 700; letter-spacing: -0.01em;
      }
      .brand-tag {
        font-size: 11px; font-weight: 500; color: var(--muted);
        letter-spacing: 0.04em;
      }
      .btn {
        display: inline-block; padding: 10px 16px; border-radius: 8px;
        background: var(--accent); color: white; text-decoration: none;
        font-weight: 600; border: 0; cursor: pointer; font-size: 14px;
      }
      .btn.secondary { background: #fff; color: var(--ink); border: 1px solid #d1d5db; }
      .btn.danger { background: #dc2626; }
      .btn:hover { opacity: 0.92; }
      input, textarea, select {
        width: 100%; padding: 10px 12px; border: 1px solid #d1d5db;
        border-radius: 8px; font-size: 14px; font-family: inherit;
      }
      textarea { resize: vertical; min-height: 100px; }
      label { display: block; font-weight: 600; margin: 12px 0 6px; font-size: 14px; }
      .grid {
        /* Fallback for browsers without column support */
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        justify-content: center;
      }
      .grid > * {
        /* Fallback: fixed width cards */
        flex: 0 0 auto;
        width: 100%;
        max-width: 280px;
        margin-bottom: 0;
      }
      /* Use columns if supported (better layout) */
      @supports (column-width: 260px) {
        .grid {
          display: block;
          column-width: 260px;
          column-gap: 16px;
        }
        .grid > * {
          break-inside: avoid;
          display: inline-block;
          width: 100%;
          max-width: none;
          margin-bottom: 16px;
        }
      }
      .note {
        padding: 18px; border-radius: 12px; box-shadow: 0 4px 14px rgba(0,0,0,0.08);
        transform: rotate(var(--rot, 0deg));
        word-wrap: break-word; overflow-wrap: anywhere;
        position: relative; overflow: hidden;
      }
      .drag-handle {
        position: absolute; top: 6px; right: 6px;
        width: 28px; height: 28px; border: 0; border-radius: 6px;
        background: rgba(0,0,0,0.06); cursor: grab; touch-action: none;
        color: #4b5563; font-size: 14px; line-height: 1;
        display: flex; align-items: center; justify-content: center;
        z-index: 2;
        user-select: none; -webkit-user-select: none;
      }
      .drag-handle:hover { background: rgba(0,0,0,0.12); color: var(--ink); }
      .drag-handle:active { cursor: grabbing; }
      .sortable-item.dragging { opacity: 0.5; outline: 2px dashed var(--accent); }
      .sortable-ghost {
        position: fixed; pointer-events: none; z-index: 1000;
        width: 240px; transform: rotate(2deg);
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
      }
      .has-motif { position: relative; overflow: hidden; }
      .has-motif::before {
        content: ''; position: absolute;
        right: 10px; bottom: 10px;
        width: 110px; height: 60px;
        background-image: var(--motif), var(--motif), var(--motif);
        background-size: 44px 44px, 32px 32px, 28px 28px;
        background-repeat: no-repeat;
        background-position: 100% 100%, 55% 80%, 15% 60%;
        pointer-events: none;
        z-index: 0;
        opacity: 0.9;
      }
      .has-motif > * { position: relative; z-index: 1; }
      .note .author { font-weight: 700; margin-top: 12px; font-size: 13px; }
      .note img { max-width: 100%; border-radius: 8px; display: block; }
      .note-body { white-space: pre-wrap; line-height: 1.5; }
      .note-body.rich { white-space: normal; }
      .note-body.rich p { margin: 0 0 8px; }
      .note-body.rich p:last-child { margin-bottom: 0; }
      .note-body.rich a { color: var(--accent); text-decoration: underline; word-break: break-word; }
      .panel {
        background: white; border-radius: 12px; padding: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      }
      .board-header {
        max-width: 720px; margin: 12px auto 28px;
        padding: 18px 28px; text-align: center;
        background: rgba(255,255,255,0.45);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 14px;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
        border: 1px solid rgba(255,255,255,0.4);
        position: relative;
      }
      .board-header h1 {
        font-size: 32px; margin: 0; font-weight: 600;
        letter-spacing: -0.01em; line-height: 1.2;
        color: var(--ink);
      }
      .board-header .recipient {
        display: block;
        margin-top: 6px;
        color: #374151;
        font-size: 14px;
      }
      @media (max-width: 600px) {
        .board-header { padding: 14px 18px; }
        .board-header h1 { font-size: 24px; }
      }

      @media (max-width: 600px) {
        .board-header { padding: 18px 22px; border-radius: 28px; }
        .board-header h1 { font-size: 26px; }
      }
      .muted { color: var(--muted); font-size: 13px; }
      .tabs { display: flex; gap: 6px; margin: 4px 0 10px; border-bottom: 1px solid #e5e7eb; }
      .tab {
        background: transparent; border: 0; padding: 8px 12px; cursor: pointer;
        font-weight: 600; color: var(--muted); border-bottom: 2px solid transparent;
        font-size: 14px;
      }
      .tab.is-active { color: var(--ink); border-bottom-color: var(--accent); }
      .giphy-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 8px;
        max-height: 360px;
        overflow-y: auto;
      }
      .giphy-grid button {
        padding: 0; border: 2px solid transparent; background: none; cursor: pointer;
        border-radius: 6px; overflow: hidden;
      }
      .giphy-grid button:hover { border-color: var(--accent); }
      .giphy-grid img { width: 100%; display: block; }
      .motif-btn {
        width: 36px; height: 36px; border-radius: 8px; cursor: pointer;
        background: rgba(255,255,255,0.7); border: 2px solid transparent;
        font-size: 18px; line-height: 1; padding: 0;
        display: inline-flex; align-items: center; justify-content: center;
      }
      .motif-btn.is-active { border-color: #1f2937; }
      .motif-btn:hover { background: rgba(255,255,255,0.95); }

      .bg-picker { display: flex; flex-wrap: wrap; gap: 8px; }
      .bg-swatch {
        width: 48px; height: 48px; border-radius: 8px; cursor: pointer;
        border: 2px solid transparent; padding: 0; overflow: hidden;
        background-color: var(--swatch-bg, #ffffff);
        background-image: var(--swatch-pattern, none);
        background-size: var(--swatch-size, 30px 30px);
        background-repeat: repeat;
        color: #9ca3af; font-size: 18px; line-height: 1;
        display: inline-flex; align-items: center; justify-content: center;
        position: relative;
      }
      .bg-swatch.is-active { border-color: #1f2937; }
      .bg-swatch:hover { transform: translateY(-1px); }

      .editor-toolbar {
        display: flex; flex-wrap: wrap; gap: 4px;
        padding: 6px; background: rgba(255,255,255,0.7);
        border: 1px solid #d1d5db; border-bottom: 0;
        border-radius: 8px 8px 0 0;
      }
      .tb {
        min-width: 30px; height: 30px; padding: 0 8px;
        border: 1px solid transparent; border-radius: 6px;
        background: transparent; cursor: pointer; font-size: 14px;
        color: var(--ink);
        display: inline-flex; align-items: center; justify-content: center;
      }
      .tb:hover { background: rgba(0,0,0,0.06); }
      .tb.is-active { background: #fff; border-color: #d1d5db; }
      .tb-sep { width: 1px; background: #d1d5db; margin: 4px 4px; align-self: stretch; }

      .editor {
        min-height: 120px; max-height: 320px; overflow-y: auto;
        padding: 10px 12px; background: #fff;
        border: 1px solid #d1d5db; border-radius: 0 0 8px 8px;
        font-size: 14px; line-height: 1.5;
        outline: none;
      }
      .editor:empty::before {
        content: attr(data-placeholder); color: #9ca3af;
      }
      .editor p { margin: 0 0 6px; }
      .editor a { color: var(--accent); text-decoration: underline; }

      .tb-emoji-wrap { position: relative; display: inline-flex; }
      .emoji-panel {
        position: absolute; top: calc(100% + 6px); right: 0;
        width: 280px; padding: 8px; background: #fff;
        border: 1px solid #d1d5db; border-radius: 8px;
        box-shadow: 0 6px 16px rgba(0,0,0,0.12);
        display: grid; grid-template-columns: repeat(8, 1fr); gap: 4px;
        max-height: 220px; overflow-y: auto;
        z-index: 20;
      }
      .emoji-panel[hidden] { display: none; }
      .emoji-panel button {
        background: none; border: 0; cursor: pointer; font-size: 20px;
        padding: 4px; border-radius: 6px; line-height: 1;
      }
      .emoji-panel button:hover { background: rgba(0,0,0,0.06); }
      /* ---- Splash overlay (recipient page) ---- */
      .splash {
        position: fixed;
        top: 0; right: 0; bottom: 0; left: 0;
        background: rgba(15, 23, 42, 0.35);
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
        display: flex; align-items: center; justify-content: center;
        z-index: 100;
        opacity: 0; pointer-events: none;
        transition: opacity 0.5s ease;
      }
      .splash.is-visible { opacity: 1; pointer-events: auto; }
      .splash.is-leaving { opacity: 0; transform: scale(1.04); transition: opacity 0.6s ease, transform 0.6s ease; }
      .splash-canvas {
        position: absolute;
        top: 0; right: 0; bottom: 0; left: 0;
        z-index: 0;
      }
      .celebrate-canvas {
        position: fixed;
        top: 0; right: 0; bottom: 0; left: 0;
        pointer-events: none;
        z-index: 90; opacity: 0; transition: opacity 0.3s ease;
      }
      .splash-floats {
        position: absolute;
        top: 0; right: 0; bottom: 0; left: 0;
        pointer-events: none; overflow: hidden; z-index: 1;
      }
      .splash-floats span {
        position: absolute; font-size: 32px;
        animation: floatUp 6s linear infinite;
        animation-fill-mode: backwards;
        opacity: 0.85;
      }
      .splash-floats span:nth-child(1) { left: 5%; animation-delay: 0s; }
      .splash-floats span:nth-child(2) { left: 18%; animation-delay: 1.2s; font-size: 26px; }
      .splash-floats span:nth-child(3) { left: 30%; animation-delay: 0.4s; font-size: 22px; }
      .splash-floats span:nth-child(4) { left: 45%; animation-delay: 2.1s; font-size: 28px; }
      .splash-floats span:nth-child(5) { left: 60%; animation-delay: 0.8s; font-size: 30px; }
      .splash-floats span:nth-child(6) { left: 72%; animation-delay: 1.5s; font-size: 26px; }
      .splash-floats span:nth-child(7) { left: 84%; animation-delay: 3.0s; font-size: 28px; }
      .splash-floats span:nth-child(8) { left: 92%; animation-delay: 2.4s; font-size: 24px; }
      .splash-floats span:nth-child(9) { left: 12%; animation-delay: 3.6s; font-size: 28px; }
      .splash-floats span:nth-child(10) { left: 67%; animation-delay: 4.2s; font-size: 26px; }
      @keyframes floatUp {
        0%   { transform: translateY(110vh) rotate(0deg); }
        100% { transform: translateY(-20vh) rotate(360deg); }
      }
      .splash-card {
        position: relative; z-index: 2;
        max-width: 460px; margin: 24px;
        padding: 36px 32px; text-align: center;
        background: rgba(255,255,255,0.96);
        border-radius: 20px;
        box-shadow: 0 24px 64px rgba(15, 23, 42, 0.35);
        animation: splashIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      @keyframes splashIn {
        0%   { transform: translateY(20px) scale(0.92); opacity: 0; }
        100% { transform: translateY(0) scale(1); opacity: 1; }
      }
      .splash-pretitle {
        margin: 0 0 8px; font-size: 13px; font-weight: 700;
        letter-spacing: 0.12em; text-transform: uppercase; color: #6b7280;
      }
      .splash-title {
        margin: 0 0 8px; font-size: 32px; line-height: 1.15;
        font-weight: 700; color: var(--ink);
      }
      .splash-recipient { margin: 0 0 24px; color: #4b5563; font-size: 15px; }
      .splash-recipient strong { color: var(--ink); font-size: 18px; }
      .splash-open {
        font-size: 16px; padding: 12px 24px;
        animation: pulseGlow 2s ease-in-out infinite;
      }
      @keyframes pulseGlow {
        0%, 100% { box-shadow: 0 4px 20px rgba(79, 70, 229, 0.35); }
        50%      { box-shadow: 0 4px 36px rgba(79, 70, 229, 0.65); }
      }

      @media (prefers-reduced-motion: reduce) {
        .splash, .splash-card, .splash-floats span, .splash-open { animation: none !important; transition: none !important; }
      }

      @media print {
        .no-print, .splash, .celebrate-canvas { display: none !important; }
        body { background: white !important; }
      }
    </style>
  </head>
  <body style={bodyStyle}>
    {!isPrint && !hideNav && (
      <div class="container no-print" style="padding-bottom:0">
        <nav class="nav">
          <a href="/" class="brand">
            <span class="brand-name">Wellspring</span>
            <span class="brand-tag">a wellspring of warm words</span>
          </a>
          <div class="nav-actions">
            {identity.email && (
              <span class="muted nav-email" title={identity.isAdmin ? `${identity.email} (Admin)` : identity.email}>
                {identity.isAdmin ? '★ ' : ''}{identity.email}
              </span>
            )}
            {identity.isAdmin && (
              <a href="/admin" class="btn secondary">Dashboard</a>
            )}
            {(identity.isAdmin || !accessConfigured) && (
              <a href="/create" class="btn secondary">New board</a>
            )}
            {loginUrl && (
              <a href={loginUrl} class="btn secondary">Sign in</a>
            )}
            {identity.email && logoutUrl && (
              <a href={logoutUrl} class="btn secondary">Sign out</a>
            )}
          </div>
        </nav>
      </div>
    )}
    <slot />
  </body>
</html>
